{
  "runner_protocol_version": 1,
  "action_registry_version": 1,
  "supported_official_actions": [
    "command",
    "wait",
    "assert_file",
    "assert_json",
    "assert_exit_code",
    "assert_output",
    "watch_logs",
    "index_artifacts",
    "end",
    "ui.navigate",
    "ui.press",
    "ui.set_input",
    "ui.scroll",
    "ui.wait_for",
    "ui.screenshot",
    "app.status",
    "app.hud",
    "cdp.target"
  ],
  "action_metadata": {
    "command": {
      "description": "Run a shell command from the project root.",
      "examples": [
        {
          "node": {
            "action": "command",
            "cmd": "pwd"
          }
        }
      ]
    },
    "wait": {
      "description": "Base wait action.",
      "examples": [
        {
          "node": {
            "action": "wait",
            "duration_ms": 1
          }
        }
      ]
    },
    "watch_logs": {
      "description": "Base log assertion/capture action.",
      "examples": [
        {
          "node": {
            "action": "watch_logs",
            "path": "logs/app.log"
          }
        }
      ]
    },
    "index_artifacts": {
      "description": "Base artifact copier/indexer.",
      "examples": [
        {
          "node": {
            "action": "index_artifacts",
            "artifacts": []
          }
        }
      ]
    },
    "end": {
      "description": "Base terminal action.",
      "examples": [
        {
          "node": {
            "action": "end",
            "status": "pass"
          }
        }
      ]
    },
    "ui.press": {
      "description": "Press/tap/click a UI target through the platform adapter.",
      "examples": [
        {
          "node": {
            "action": "ui.press",
            "target": "Perps"
          }
        }
      ]
    },
    "ui.scroll": {
      "description": "Scroll through the UI through the Farmslot base platform adapter. Supports deltas and scroll_into_view for selector/test-id proof positioning.",
      "examples": [
        {
          "node": {
            "action": "ui.scroll",
            "delta_y": 300
          }
        },
        {
          "description": "Bring a React Native testID into view before screenshot proof",
          "node": {
            "action": "ui.scroll",
            "test_id": "wallet-screen",
            "scroll_into_view": true
          }
        }
      ],
      "proof_effect": "E2E validation must include a passing ui-scroll-into-view trace event with output.intoView=true."
    },
    "ui.wait_for": {
      "description": "Wait for a UI condition through the platform adapter.",
      "examples": [
        {
          "node": {
            "action": "ui.wait_for",
            "text": "Perps"
          }
        }
      ]
    },
    "ui.screenshot": {
      "description": "Capture visual evidence through the platform adapter.",
      "examples": [
        {
          "node": {
            "action": "ui.screenshot",
            "path": "screenshots/example.json"
          }
        }
      ]
    },
    "assert_file": {
      "description": "Assert that a project file exists and optionally contains text.",
      "examples": [
        {
          "node": {
            "action": "assert_file",
            "path": "reports/result.txt",
            "contains": "ok"
          }
        }
      ]
    },
    "assert_json": {
      "description": "Assert a JSON file value with a JSONPath-style selector.",
      "examples": [
        {
          "node": {
            "action": "assert_json",
            "path": "reports/result.json",
            "assert": {
              "path": "$.status",
              "operator": "eq",
              "value": "ok"
            }
          }
        }
      ]
    },
    "assert_exit_code": {
      "description": "Assert the exit code captured from a command node output.",
      "examples": [
        {
          "node": {
            "action": "assert_exit_code",
            "source": "run-tests",
            "expected": 0
          }
        }
      ]
    },
    "assert_output": {
      "description": "Assert stdout or stderr captured from a command node output.",
      "examples": [
        {
          "node": {
            "action": "assert_output",
            "source": "run-tests",
            "stream": "stdout",
            "contains": "PASS"
          }
        }
      ]
    },
    "app.hud": {
      "description": "Display minimal human-readable recipe progress. The intent must explain the current agent goal; debug metadata and flow/domain labels are hidden unless explicitly opted in.",
      "examples": [
        {
          "description": "Default one-intent progress HUD",
          "node": {
            "action": "app.hud",
            "status": "running",
            "intent": "Open a small ETH long position",
            "progress": {
              "current": 12,
              "total": 19
            }
          }
        },
        {
          "description": "Explicit composed subflow context",
          "node": {
            "action": "app.hud",
            "status": "running",
            "intent": "Open a small ETH long position",
            "sub_intent": "Validate Perps lifecycle smoke",
            "display": {
              "showSubflow": true
            },
            "progress": {
              "current": 12,
              "total": 19
            }
          }
        }
      ],
      "safety_notes": "HUD is reviewer feedback only. It must not mutate product state or carry task assertions; trace/artifacts remain authoritative."
    },
    "ui.set_input": {
      "description": "Set text on a React Native TextInput by testID through the app control bridge.",
      "schema": {
        "type": "object",
        "properties": {
          "test_id": {
            "type": "string"
          },
          "testID": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "next": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "examples": [
        {
          "node": {
            "action": "ui.set_input",
            "test_id": "network-selector-network-search-input",
            "value": "Sepolia"
          }
        }
      ]
    }
  },
